---
// Carril derecho de /api (200px): CTA "¿tu primer plugin?" (borde key) → /plugins,
// índice `§ en esta página` (las funciones/secciones de la página; activo bright
// vía scrollspy) y metadata "generada desde docs/contracts/api.md · <hash> · hace N días"
// tomada de git (la fuente de la referencia es docs/contracts/api.md, no estas páginas).
import { i18n, type Lang } from '../../lib/i18n';
import { gitMeta } from '../../lib/gitmeta';

interface Heading {
  depth: number;
  slug: string;
  text: string;
}
interface Props {
  headings: Heading[];
  lang?: Lang;
}
const { headings, lang = 'es' } = Astro.props;
const base = import.meta.env.BASE_URL;
const pref = lang === 'en' ? 'en/' : '';
const t = i18n[lang]; // build-time en el idioma de la página; el swap es en cliente (data-i18n)

// Etiqueta corta de una sección: último segmento de sus callables
// (`enu.fs.read` → `read`, `enu.fs.write / enu.fs.append` → `write / append`), o el
// texto limpio si el heading no nombra funciones (`Manipulación`).
function etiquetaSeccion(text: string): string {
  const limpio = text.replaceAll('⏸', '').replaceAll('[W]', '').trim();
  const nombres = limpio.match(/enu\.[\w.]+|[A-Z][A-Za-z]*:[a-z_]\w*/g);
  if (nombres) return nombres.map((n) => n.split(/[.:]/).pop()).join(' / ');
  return limpio;
}

const secciones = headings
  .filter((h) => h.depth === 2)
  .map((h) => ({ slug: h.slug, label: etiquetaSeccion(h.text) }));

const meta = gitMeta('docs/contracts/api.md');
const dias = meta
  ? lang === 'en'
    ? meta.diasDesde === 0
      ? 'today'
      : `${meta.diasDesde} day${meta.diasDesde === 1 ? '' : 's'} ago`
    : meta.diasDesde === 0
      ? 'hoy'
      : `hace ${meta.diasDesde} día${meta.diasDesde === 1 ? '' : 's'}`
  : '';
---
<aside class="api-rail">
  <a class="cta" href={`${base}${pref}plugins`}>
    <div class="cta-title" data-i18n="ctaTitle">{t.ctaTitle}</div>
    <div class="cta-body" data-i18n="ctaBody">{t.ctaBody}</div>
    <span class="cta-link" data-i18n="ctaLink">{t.ctaLink}</span>
  </a>

  {secciones.length > 0 && (
    <>
      <div class="rail-h">§ <span data-i18n="onPage">{t.onPage}</span></div>
      <nav class="rail-secs">
        {secciones.map((s, i) => (
          <a href={`#${s.slug}`} class={i === 0 ? 'sec active' : 'sec'} data-sec={s.slug}>{s.label}</a>
        ))}
      </nav>
    </>
  )}

  <div class="rail-meta">
    {meta && (
      <div class="meta-gen">
        <span data-i18n="genFrom">{t.genFrom}</span><span class="key">{meta.hash}</span> · {dias}
      </div>
    )}
    <div class="meta-adr">
      <span data-i18n="sagrada">{t.sagrada}</span>{' '}
      <a href={`${base}${pref}docs/adr`} class="key" data-i18n="adrLink">{t.adrLink}</a>
    </div>
  </div>
</aside>
