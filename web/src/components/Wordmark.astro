---
// Wordmark: `enu` en caja invertida (background bright, color bg). Ancla de marca
// constante en todos los themes. Estilo en global.css (.enu-wordmark). Enlaza a
// la portada salvo que se pase href="".
interface Props {
  href?: string;
}
const base = import.meta.env.BASE_URL;
const { href = base } = Astro.props;
---
{href ? (
  <a class="enu-wordmark" href={href}>enu</a>
) : (
  <span class="enu-wordmark">enu</span>
)}
