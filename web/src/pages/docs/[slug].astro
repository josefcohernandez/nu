---
// Página de la wiki (pantalla 12a). Grid de 3 columnas: sidebar 240px (borde
// derecho) + contenido (max ~68ch) + carril derecho 180px. En <768px el sidebar
// y el carril desaparecen: el índice vive tras `[≡]` (drawer) y prev/next pasan
// a filas táctiles grandes.
import { getCollection, render } from 'astro:content';
import Base from '../../layouts/Base.astro';
import HeaderInternal from '../../components/HeaderInternal.astro';
import Statusline from '../../components/Statusline.astro';
import Sidebar from '../../components/wiki/Sidebar.astro';
import { DOCS, TOTAL, urlDoc } from '../../lib/docmap';
import { gitMeta } from '../../lib/gitmeta';
import { i18n } from '../../lib/i18n';
import '../../styles/markdown.css';

export async function getStaticPaths() {
  const [wiki, empezar, extensiones] = await Promise.all([
    getCollection('wiki'),
    getCollection('empezar'),
    getCollection('extensiones'),
  ]);
  const porId = new Map<string, any>();
  for (const e of wiki) porId.set(`wiki:${e.id}`, e);
  for (const e of empezar) porId.set(`empezar:${e.id}`, e);
  for (const e of extensiones) porId.set(`extensiones:${e.id}`, e);

  return DOCS.map((doc, i) => ({
    params: { slug: doc.slug },
    props: {
      doc,
      entry: porId.get(`${doc.collection}:${doc.slug}`),
      index: i,
      prev: i > 0 ? DOCS[i - 1] : null,
      next: i < DOCS.length - 1 ? DOCS[i + 1] : null,
    },
  }));
}

const { doc, entry, index, prev, next } = Astro.props;
const es = i18n.es; // build-time en ES; el swap a EN es en cliente

const { Content, headings } = await render(entry);

// Título: frontmatter (empezar, extensiones) o el primer H1 del .md (wiki). Las
// páginas locales (empezar y extensiones) no traen H1 en el cuerpo: se pinta
// aquí para que reciba el mismo estilo (═) que un H1 de markdown.
const usaFrontmatter = doc.collection === 'empezar' || doc.collection === 'extensiones';
const tituloH1 = headings.find((h) => h.depth === 1)?.text;
const titulo = usaFrontmatter ? (entry.data.title as string) : (tituloH1 ?? doc.slug);

// Índice del carril: los h2 del documento.
const toc = headings.filter((h) => h.depth === 2);

// Metadatos de git de la ruta fuente.
const meta = gitMeta(doc.gitPath);
const posicion = `${index + 1}/${TOTAL}`;

const routePath = `docs/${doc.slug}.md`;
const nextUrl = next ? urlDoc(next.slug) : null;
const prevUrl = prev ? urlDoc(prev.slug) : null;

// Teclas de la statusline (orden del prototipo 12a). Las etiquetas salen de
// i18n.es y llevan su clave data-i18n para el swap de idioma en cliente.
const keys = [
  { k: 'j/k', label: es.kScroll, i18n: 'kScroll' },
  { k: 'n/p', label: es.kDoc, i18n: 'kDoc' },
  { k: ':', label: es.kCmd, i18n: 'kCmd' },
  { k: '/', label: es.kSearch, i18n: 'kSearch' },
  { k: 'q', label: es.kBack, i18n: 'kBack' },
];

// Ago inicial en ES (el cliente lo ajusta al idioma y lo re-renderiza).
function agoEs(n: number): string {
  return n === 1 ? 'hace 1 día' : `hace ${n} días`;
}
---
<Base title={`${titulo} · nu`} description={(entry.data.description as string) ?? titulo}>
  <div class="wiki">
    <HeaderInternal active="docs" routePath={routePath} />

    <div class="wiki-grid">
      <!-- Sidebar (desktop). -->
      <aside class="col-side">
        <Sidebar activeSlug={doc.slug} />
      </aside>

      <!-- Contenido. -->
      <main class="col-main">
        <article class="markdown">
          {usaFrontmatter && <h1>{titulo}</h1>}
          <Content />
        </article>

        <!-- Pie: prev/next. -->
        <nav class="prevnext">
          {prev ? (
            <a class="pn prev" href={prevUrl}>
              <span class="pn-lbl" data-i18n="prev">{es.prev}</span>
              <span class="pn-file">{prev.slug}.md</span>
            </a>
          ) : (
            <span class="pn-empty"></span>
          )}
          {next && (
            <a class="pn next" href={nextUrl}>
              <span class="pn-lbl" data-i18n="next">{es.next}</span>
              <span class="pn-file">{next.slug}.md →</span>
            </a>
          )}
        </nav>
      </main>

      <!-- Carril derecho. -->
      <aside class="col-rail">
        {toc.length > 0 && (
          <div class="toc">
            <div class="toc-title">§ <span data-i18n="onPage">{es.onPage}</span></div>
            <div class="toc-list">
              {toc.map((h, i) => (
                <a href={`#${h.slug}`} class={i === 0 ? 'toc-link activo' : 'toc-link'}>{h.text}</a>
              ))}
            </div>
          </div>
        )}
        {meta && (
          <div class="meta">
            <span data-i18n="commit">{es.commit}</span><br />
            <span class="hash">{meta.hash}</span> · <span class="ago" data-dias={meta.diasDesde}>{agoEs(meta.diasDesde)}</span>
          </div>
        )}
      </aside>
    </div>

    <Statusline left={`${routePath} · 0% · ${posicion}`} keys={keys} />

    <!-- Botón de índice móvil + drawer overlay (misma lista del sidebar). -->
    <button type="button" class="drawer-abre" data-drawer-toggle aria-label="índice">[≡]</button>
    <div class="drawer" data-drawer>
      <div class="drawer-backdrop" data-drawer-toggle></div>
      <div class="drawer-panel">
        <div class="drawer-head">
          <span class="dim">docs/</span><span class="bright">{doc.slug}.md</span>
          <button type="button" class="drawer-cierra" data-drawer-toggle aria-label="cerrar">[×]</button>
        </div>
        <Sidebar activeSlug={doc.slug} />
      </div>
    </div>
  </div>

  <script>
    import { initPager } from '../../scripts/pager';
    import { initMermaid } from '../../scripts/mermaid-init';

    const data = document.getElementById('nu-wiki-data');
    const ctx = data?.getAttribute('data-ctx') ?? '';
    const pos = data?.getAttribute('data-pos') ?? '';
    const nextUrl = data?.getAttribute('data-next') || null;
    const prevUrl = data?.getAttribute('data-prev') || null;

    initPager({ context: ctx, pos, withPercent: true, nextUrl, prevUrl });
    void initMermaid();

    // El drawer móvil ([≡] flotante, `[≡] índice` de la statusline, backdrop y
    // cerrar) lo cablea initPager por atributos: no hace falta nada aquí.

    // «hace N días» bilingüe: ES por defecto, EN al cambiar data-lang.
    const ago = document.querySelector<HTMLElement>('.ago');
    if (ago) {
      const n = parseInt(ago.getAttribute('data-dias') ?? '0', 10);
      const pintaAgo = (): void => {
        const en = document.documentElement.getAttribute('data-lang') === 'en';
        ago.textContent = en
          ? n === 1 ? '1 day ago' : `${n} days ago`
          : n === 1 ? 'hace 1 día' : `hace ${n} días`;
      };
      pintaAgo();
      new MutationObserver(pintaAgo).observe(document.documentElement, {
        attributes: true,
        attributeFilter: ['data-lang'],
      });
    }

    // Scroll-spy del carril: resalta el §h2 visible.
    const enlaces = Array.from(document.querySelectorAll<HTMLElement>('.toc-link'));
    if (enlaces.length > 0) {
      const porId = new Map<string, HTMLElement>();
      enlaces.forEach((a) => {
        const id = a.getAttribute('href')?.slice(1);
        if (id) porId.set(id, a);
      });
      const encabezados = Array.from(document.querySelectorAll<HTMLElement>('.markdown h2'));
      const obs = new IntersectionObserver(
        (entradas) => {
          const visible = entradas.find((e) => e.isIntersecting);
          if (!visible) return;
          const id = visible.target.id;
          enlaces.forEach((a) => a.classList.remove('activo'));
          porId.get(id)?.classList.add('activo');
        },
        { rootMargin: '0px 0px -70% 0px', threshold: 0 },
      );
      encabezados.forEach((h) => obs.observe(h));
    }
  </script>

  <!-- Datos para el script (evita interpolar en el módulo). -->
  <span
    id="nu-wiki-data"
    hidden
    data-ctx={routePath}
    data-pos={posicion}
    data-next={nextUrl ?? ''}
    data-prev={prevUrl ?? ''}
  ></span>
</Base>

<style>
  .wiki {
    display: flex;
    flex-direction: column;
    min-height: 100vh;
    min-height: 100dvh;
  }
  .wiki-grid {
    flex: 1;
    display: grid;
    grid-template-columns: 240px minmax(0, 1fr) 180px;
    align-items: start;
  }
  .col-side {
    border-right: 1px solid var(--border);
    padding: 24px 0;
    position: sticky;
    top: 0;
    align-self: start;
    max-height: 100vh;
    max-height: 100dvh;
    overflow-y: auto;
  }
  .col-main {
    padding: 36px 52px;
    min-width: 0;
  }
  .col-rail {
    padding: 36px 26px 0 0;
    font-size: 11.5px;
    line-height: 2;
    position: sticky;
    top: 0;
    align-self: start;
    max-height: 100vh;
    max-height: 100dvh;
    overflow-y: auto;
  }

  /* Carril: índice §. */
  .toc-title {
    color: var(--dim);
    margin-bottom: 2px;
  }
  .toc-list {
    display: flex;
    flex-direction: column;
  }
  .toc-link {
    color: var(--dim);
    padding: 1px 0;
  }
  .toc-link.activo {
    color: var(--bright);
  }
  .meta {
    margin-top: 22px;
    color: var(--dim);
    font-size: 10.5px;
    line-height: 1.8;
    border-top: 1px solid var(--border);
    padding-top: 12px;
  }
  .meta .hash {
    color: var(--key);
  }

  /* Pie prev/next (desktop): fila con borde superior. */
  .prevnext {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 16px;
    margin-top: 8px;
    padding-top: 14px;
    border-top: 1px solid var(--border);
    font-size: 12.5px;
    max-width: 68ch;
  }
  .pn {
    display: inline-flex;
    gap: 8px;
    align-items: baseline;
  }
  .pn.prev {
    color: var(--dim);
  }
  .pn.next {
    color: var(--key);
    margin-left: auto;
  }
  .pn.prev .pn-file {
    color: var(--fg);
  }
  .pn-empty {
    flex: 1;
  }

  /* Botón de índice móvil y drawer: ocultos en desktop. */
  .drawer-abre,
  .drawer {
    display: none;
  }

  @media (max-width: 767px) {
    /* Una sola columna: sidebar y carril fuera. */
    .wiki-grid {
      grid-template-columns: 1fr;
    }
    .col-side,
    .col-rail {
      display: none;
    }
    .col-main {
      padding: 26px 24px;
    }

    /* prev/next como dos filas táctiles grandes. */
    .prevnext {
      flex-direction: column;
      gap: 10px;
      border-top: none;
      padding-top: 0;
      max-width: none;
    }
    .pn {
      display: flex;
      justify-content: space-between;
      border: 1px solid var(--border);
      padding: 13px 14px;
      min-height: 48px;
      font-size: 12px;
    }
    .pn.next {
      margin-left: 0;
    }
    .pn-empty {
      display: none;
    }

    /* Botón [≡] flotante para abrir el índice. */
    .drawer-abre {
      display: block;
      position: fixed;
      top: 12px;
      right: 16px;
      z-index: 30;
      background: none;
      border: none;
      color: var(--key);
      font: inherit;
      font-weight: 600;
      font-size: 14px;
      padding: 6px;
      cursor: pointer;
    }

    /* Drawer overlay: misma lista del sidebar a ancho completo. */
    .drawer {
      display: block;
      position: fixed;
      inset: 0;
      z-index: 40;
      visibility: hidden;
    }
    .drawer.abierto {
      visibility: visible;
    }
    .drawer-backdrop {
      position: absolute;
      inset: 0;
      background: var(--bg);
      opacity: 0.7;
    }
    .drawer-panel {
      position: absolute;
      inset: 0;
      background: var(--bg);
      border-right: 1px solid var(--border);
      overflow-y: auto;
      padding: 20px 0;
    }
    .drawer-head {
      display: flex;
      align-items: center;
      gap: 8px;
      padding: 0 24px 16px;
      font-size: 12px;
      border-bottom: 1px solid var(--border);
      margin-bottom: 16px;
    }
    .drawer-head .dim {
      color: var(--dim);
    }
    .drawer-head .bright {
      color: var(--bright);
    }
    .drawer-cierra {
      margin-left: auto;
      background: none;
      border: none;
      color: var(--key);
      font: inherit;
      font-weight: 600;
      cursor: pointer;
      padding: 4px;
    }
  }
</style>
